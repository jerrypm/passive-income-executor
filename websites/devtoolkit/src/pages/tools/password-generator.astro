---
import ToolLayout from '../../layouts/ToolLayout.astro';
---

<ToolLayout
  title="Free Strong Password Generator Online"
  description="Generate cryptographically strong random passwords with customizable length, character sets, and bulk generation. Check password strength instantly."
  keywords={["password generator", "strong password", "random password", "secure password", "password strength", "bulk password generator", "password creator"]}
  relatedTools={[
    { name: "Hash Generator", href: "/tools/hash-generator" },
    { name: "UUID Generator", href: "/tools/uuid-generator" },
    { name: "Base64 Encoder", href: "/tools/base64-encoder" },
    { name: "Lorem Ipsum Generator", href: "/tools/lorem-ipsum-generator" }
  ]}
>
  <!-- Main Password Display -->
  <div class="mb-6">
    <label class="block text-sm font-medium text-text-muted mb-2">Generated Password</label>
    <div class="flex gap-3">
      <input id="password-output" type="text" readonly class="flex-1 bg-surface border border-border rounded-lg p-4 text-text font-mono text-lg focus:outline-none focus:ring-2 focus:ring-primary" value="" />
      <button id="btn-copy" class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-colors">Copy</button>
      <button id="btn-generate" class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white font-medium rounded-lg transition-colors">Generate</button>
    </div>
  </div>

  <!-- Strength Meter -->
  <div class="mb-6">
    <div class="flex justify-between items-center mb-1">
      <label class="text-sm font-medium text-text-muted">Password Strength</label>
      <span id="strength-label" class="text-sm font-medium">-</span>
    </div>
    <div class="w-full bg-surface border border-border rounded-full h-3 overflow-hidden">
      <div id="strength-bar" class="h-full rounded-full transition-all duration-300" style="width: 0%; background-color: #666;"></div>
    </div>
    <div id="strength-details" class="text-xs text-text-muted mt-1"></div>
  </div>

  <!-- Options -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Left: Length & Characters -->
    <div>
      <label class="block text-sm font-medium text-text-muted mb-2">
        Password Length: <span id="length-display" class="text-text font-semibold">16</span>
      </label>
      <input id="length-slider" type="range" min="8" max="128" value="16" class="w-full h-2 bg-surface border border-border rounded-lg appearance-none cursor-pointer accent-primary" />
      <div class="flex justify-between text-xs text-text-muted mt-1">
        <span>8</span>
        <span>32</span>
        <span>64</span>
        <span>128</span>
      </div>

      <div class="mt-4">
        <label class="block text-sm font-medium text-text-muted mb-2">Custom Symbols</label>
        <input id="custom-symbols" type="text" value="!@#$%^&*()_+-=[]{}|;:',.<>?/`~" class="w-full bg-surface border border-border rounded-lg p-3 text-text font-mono text-sm focus:outline-none focus:ring-2 focus:ring-primary" />
      </div>
    </div>

    <!-- Right: Checkboxes -->
    <div>
      <label class="block text-sm font-medium text-text-muted mb-2">Character Sets</label>
      <div class="space-y-3">
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="opt-uppercase" checked class="rounded border-border bg-surface text-primary focus:ring-primary" />
          <span class="text-sm text-text">Uppercase (A-Z)</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="opt-lowercase" checked class="rounded border-border bg-surface text-primary focus:ring-primary" />
          <span class="text-sm text-text">Lowercase (a-z)</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="opt-numbers" checked class="rounded border-border bg-surface text-primary focus:ring-primary" />
          <span class="text-sm text-text">Numbers (0-9)</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="opt-symbols" checked class="rounded border-border bg-surface text-primary focus:ring-primary" />
          <span class="text-sm text-text">Symbols (!@#$...)</span>
        </label>
        <label class="flex items-center gap-3 cursor-pointer">
          <input type="checkbox" id="opt-exclude-similar" class="rounded border-border bg-surface text-primary focus:ring-primary" />
          <span class="text-sm text-text">Exclude similar characters (0, O, l, 1, I)</span>
        </label>
      </div>
    </div>
  </div>

  <!-- Bulk Generate -->
  <div class="mb-4">
    <div class="flex items-center gap-3 mb-2">
      <label class="text-sm font-medium text-text-muted">Bulk Generate</label>
      <select id="bulk-count" class="bg-surface border border-border rounded-lg p-2 text-text text-sm focus:outline-none focus:ring-2 focus:ring-primary">
        <option value="5">5 passwords</option>
        <option value="10">10 passwords</option>
        <option value="15">15 passwords</option>
        <option value="20">20 passwords</option>
      </select>
      <button id="btn-bulk" class="px-4 py-2 bg-surface-lighter hover:bg-border text-text-muted font-medium rounded-lg transition-colors text-sm">Generate Bulk</button>
      <button id="btn-copy-bulk" class="px-4 py-2 bg-surface-lighter hover:bg-border text-text-muted font-medium rounded-lg transition-colors text-sm">Copy All</button>
    </div>
    <textarea id="bulk-output" class="w-full bg-surface border border-border rounded-lg p-4 text-text font-mono text-sm focus:outline-none focus:ring-2 focus:ring-primary resize-y min-h-[200px] hidden" readonly></textarea>
  </div>

  <script>
    const passwordOutput = document.getElementById('password-output') as HTMLInputElement;
    const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
    const lengthDisplay = document.getElementById('length-display')!;
    const strengthBar = document.getElementById('strength-bar')!;
    const strengthLabel = document.getElementById('strength-label')!;
    const strengthDetails = document.getElementById('strength-details')!;
    const customSymbols = document.getElementById('custom-symbols') as HTMLInputElement;
    const bulkOutput = document.getElementById('bulk-output') as HTMLTextAreaElement;

    const optUppercase = document.getElementById('opt-uppercase') as HTMLInputElement;
    const optLowercase = document.getElementById('opt-lowercase') as HTMLInputElement;
    const optNumbers = document.getElementById('opt-numbers') as HTMLInputElement;
    const optSymbols = document.getElementById('opt-symbols') as HTMLInputElement;
    const optExcludeSimilar = document.getElementById('opt-exclude-similar') as HTMLInputElement;

    const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz';
    const NUMBERS = '0123456789';
    const SIMILAR_CHARS = '0OlL1Ii|';

    function getCharset(): string {
      let charset = '';
      if (optUppercase.checked) charset += UPPERCASE;
      if (optLowercase.checked) charset += LOWERCASE;
      if (optNumbers.checked) charset += NUMBERS;
      if (optSymbols.checked) charset += customSymbols.value;

      if (optExcludeSimilar.checked) {
        charset = charset.split('').filter(c => !SIMILAR_CHARS.includes(c)).join('');
      }

      // Remove duplicates
      charset = [...new Set(charset.split(''))].join('');
      return charset;
    }

    function generatePassword(length: number): string {
      const charset = getCharset();
      if (charset.length === 0) return '(select at least one character set)';

      const array = new Uint32Array(length);
      crypto.getRandomValues(array);

      // Ensure at least one from each selected set
      const requiredSets: string[] = [];
      if (optUppercase.checked) {
        let set = UPPERCASE;
        if (optExcludeSimilar.checked) set = set.split('').filter(c => !SIMILAR_CHARS.includes(c)).join('');
        if (set.length > 0) requiredSets.push(set);
      }
      if (optLowercase.checked) {
        let set = LOWERCASE;
        if (optExcludeSimilar.checked) set = set.split('').filter(c => !SIMILAR_CHARS.includes(c)).join('');
        if (set.length > 0) requiredSets.push(set);
      }
      if (optNumbers.checked) {
        let set = NUMBERS;
        if (optExcludeSimilar.checked) set = set.split('').filter(c => !SIMILAR_CHARS.includes(c)).join('');
        if (set.length > 0) requiredSets.push(set);
      }
      if (optSymbols.checked && customSymbols.value.length > 0) {
        let set = customSymbols.value;
        if (optExcludeSimilar.checked) set = set.split('').filter(c => !SIMILAR_CHARS.includes(c)).join('');
        if (set.length > 0) requiredSets.push(set);
      }

      let password = '';
      for (let i = 0; i < length; i++) {
        password += charset[array[i] % charset.length];
      }

      // Replace first N characters with one from each required set
      if (requiredSets.length > 0 && length >= requiredSets.length) {
        const passwordArr = password.split('');
        const positions: number[] = [];
        // Pick random positions
        const posArray = new Uint32Array(requiredSets.length);
        crypto.getRandomValues(posArray);
        const available = Array.from({ length }, (_, i) => i);
        for (let i = 0; i < requiredSets.length; i++) {
          const idx = posArray[i] % available.length;
          positions.push(available[idx]);
          available.splice(idx, 1);
        }
        const charArray = new Uint32Array(requiredSets.length);
        crypto.getRandomValues(charArray);
        for (let i = 0; i < requiredSets.length; i++) {
          passwordArr[positions[i]] = requiredSets[i][charArray[i] % requiredSets[i].length];
        }
        password = passwordArr.join('');
      }

      return password;
    }

    function calculateStrength(password: string): { score: number; label: string; color: string; details: string } {
      if (password.startsWith('(')) return { score: 0, label: '-', color: '#666', details: '' };

      let score = 0;
      const length = password.length;

      // Length scoring
      if (length >= 8) score += 1;
      if (length >= 12) score += 1;
      if (length >= 16) score += 1;
      if (length >= 24) score += 1;
      if (length >= 32) score += 1;

      // Character variety
      const hasUpper = /[A-Z]/.test(password);
      const hasLower = /[a-z]/.test(password);
      const hasNumber = /[0-9]/.test(password);
      const hasSymbol = /[^A-Za-z0-9]/.test(password);

      const typesUsed = [hasUpper, hasLower, hasNumber, hasSymbol].filter(Boolean).length;
      score += typesUsed;

      // Unique characters ratio
      const unique = new Set(password).size;
      const uniqueRatio = unique / length;
      if (uniqueRatio > 0.7) score += 1;
      if (uniqueRatio > 0.9) score += 1;

      // Entropy calculation
      let charsetSize = 0;
      if (hasUpper) charsetSize += 26;
      if (hasLower) charsetSize += 26;
      if (hasNumber) charsetSize += 10;
      if (hasSymbol) charsetSize += 32;
      const entropy = Math.floor(length * Math.log2(charsetSize || 1));

      let label: string;
      let color: string;
      let percentage: number;

      if (score <= 3) {
        label = 'Weak';
        color = '#ef4444';
        percentage = 25;
      } else if (score <= 5) {
        label = 'Fair';
        color = '#f59e0b';
        percentage = 50;
      } else if (score <= 8) {
        label = 'Strong';
        color = '#22c55e';
        percentage = 75;
      } else {
        label = 'Very Strong';
        color = '#10b981';
        percentage = 100;
      }

      const details = `${entropy} bits of entropy | ${unique} unique chars | ${typesUsed} character type${typesUsed !== 1 ? 's' : ''}`;

      return { score: percentage, label, color, details };
    }

    function updateStrength(password: string) {
      const { score, label, color, details } = calculateStrength(password);
      strengthBar.style.width = `${score}%`;
      strengthBar.style.backgroundColor = color;
      strengthLabel.textContent = label;
      strengthLabel.style.color = color;
      strengthDetails.textContent = details;
    }

    function generate() {
      const length = parseInt(lengthSlider.value);
      const password = generatePassword(length);
      passwordOutput.value = password;
      updateStrength(password);
    }

    // Event listeners
    lengthSlider.addEventListener('input', () => {
      lengthDisplay.textContent = lengthSlider.value;
      generate();
    });

    [optUppercase, optLowercase, optNumbers, optSymbols, optExcludeSimilar].forEach(el => {
      el.addEventListener('change', generate);
    });

    customSymbols.addEventListener('input', () => {
      if (optSymbols.checked) generate();
    });

    document.getElementById('btn-generate')!.addEventListener('click', generate);

    document.getElementById('btn-copy')!.addEventListener('click', () => {
      navigator.clipboard.writeText(passwordOutput.value);
      const btn = document.getElementById('btn-copy')!;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy', 1500);
    });

    document.getElementById('btn-bulk')!.addEventListener('click', () => {
      const count = parseInt((document.getElementById('bulk-count') as HTMLSelectElement).value);
      const length = parseInt(lengthSlider.value);
      const passwords: string[] = [];
      for (let i = 0; i < count; i++) {
        passwords.push(generatePassword(length));
      }
      bulkOutput.value = passwords.join('\n');
      bulkOutput.classList.remove('hidden');
    });

    document.getElementById('btn-copy-bulk')!.addEventListener('click', () => {
      if (bulkOutput.value) {
        navigator.clipboard.writeText(bulkOutput.value);
        const btn = document.getElementById('btn-copy-bulk')!;
        btn.textContent = 'Copied!';
        setTimeout(() => btn.textContent = 'Copy All', 1500);
      }
    });

    // Generate initial password
    generate();
  </script>

  <Fragment slot="howto">
    <ol class="list-decimal list-inside text-text-muted space-y-2 text-sm">
      <li>Adjust the slider to set your desired password length (8 to 128 characters).</li>
      <li>Select which character types to include: uppercase, lowercase, numbers, and symbols.</li>
      <li>Optionally exclude similar-looking characters (0, O, l, 1, I) to avoid confusion.</li>
      <li>Customize the symbols set if needed.</li>
      <li>Click Generate or change any option to create a new password instantly.</li>
      <li>Check the strength meter to ensure your password is strong enough.</li>
      <li>Use Bulk Generate to create multiple passwords at once (up to 20).</li>
      <li>Click Copy to copy any password to your clipboard.</li>
    </ol>
  </Fragment>
</ToolLayout>
